# --- AWS / S3 ---
S3_BUCKET=magic-content-dev
# The Importer hardcodes Prefix: 'output/' — changing this value will break post discovery.
S3_KEY_PREFIX=output/

# --- mce-second-brain (bullpen architecture) ---
# S3 bucket for the bullpen pipeline (ap-southeast-2).
MCE_SECOND_BRAIN_BUCKET=mce-second-brain
# output/ is hardcoded in the admin importer — do not change without updating the importer.
MCE_S3_KEY_PREFIX=output/
MCE_S3_AMI_CONTEXT_PREFIX=ami-context/
MCE_S3_ARCHIVE_PREFIX=archive/

# DynamoDB tables — all use on-demand billing (PAY_PER_REQUEST)
MCE_CHECKPOINTS_TABLE=mce-checkpoints
MCE_TOPIC_COVERAGE_TABLE=mce-topic-coverage
MCE_DEDUPLICATION_TABLE=mce-deduplication
MCE_HELD_ITEMS_TABLE=mce-held-items

# --- Steering ---
STEERING_BASE_PATH=.kiro/steering/

# --- Bedrock model IDs ---
HAIKU_MODEL_ID=anthropic.claude-haiku-4-5-20251001-v1:0
SONNET_MODEL_ID=anthropic.claude-sonnet-4-6

# --- Scoring ---
RELEVANCE_THRESHOLD=3

# --- Screenshot ---
SCREENSHOT_VIEWPORT_W=1440
SCREENSHOT_VIEWPORT_H=900
SCREENSHOT_WAIT_S=3

# --- Retry ---
MAX_RETRY_ATTEMPTS=3

# --- Logging ---
LOG_LEVEL=DEBUG

# --- SES ---
SES_SENDER_EMAIL=your-verified-sender@example.com
SES_RECIPIENT_EMAIL=your-recipient@example.com

# --- Output paths ---
HELD_OUTPUT_PATH=./output/held/
REVIEW_OUTPUT_PATH=./output/review/

# --- dev.to ---
DEVTO_API_KEY=your-devto-api-key
DEVTO_USERNAME=your-devto-username

# --- GitHub ---
GITHUB_TOKEN=your-github-pat

# --- kiro-recall vault ---
VAULT_PATH=/path/to/your/second-brain
